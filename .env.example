# AI Firewall — environment configuration. Copy to .env and fill in.
# .env is gitignored — never commit real secrets.

# Claude API (detection)
ANTHROPIC_API_KEY=sk-ant-...

# --- Gate 3 auth ---

# Session signing key. Generate: python -c "import secrets; print(secrets.token_hex(32))"
FIREWALL_SECRET_KEY=

# Human dashboard login.
FIREWALL_USERNAME=admin
# Password HASH, not the password. Generate: python auth.py hash <password>
FIREWALL_PASSWORD_HASH=

# Machine API key for POST /analyse (sent as the X-API-Key header).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
FIREWALL_API_KEY=

# Set to "true" only when serving over HTTPS (Gate 4) to mark cookies Secure.
FIREWALL_COOKIE_SECURE=false
